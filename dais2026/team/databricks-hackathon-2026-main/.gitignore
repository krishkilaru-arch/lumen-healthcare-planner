# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment (secrets — never commit)
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Node / Playwright
node_modules/
.playwright/
.playwright-cli/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Databricks ---
# Never commit credentials
.databrickscfg
*.databrickscfg
# Workspace/bundle state is machine-specific — ignore all of .databricks/
# EXCEPT the project-scoped aitools skills, which we commit so they travel
# with the repo (the .claude/ and .cursor/ symlinks point here).
.databricks/*
!.databricks/aitools/
.databricks/aitools/*
!.databricks/aitools/skills/
# DABs build artifacts
build/

# --- Secrets / env ---
.env
.env.*
*.pem
*.key
secrets/

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# --- Node ---
node_modules/
dist/
client/dist/
.smoke-test/
test-results/
playwright-report/
# Auto-generated AppKit types (endpoint-specific, varies per developer)
shared/appkit-types/serving.d.ts

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.log


# Editor agent dirs: ignore local settings, but commit project-scoped
# skills + MCP config so they travel with the repo.
.claude/*
!.claude/skills/
.cursor/*
!.cursor/skills/
!.cursor/mcp.json
